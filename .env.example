# =============================================
# KONFIGURASI API KEYS
# =============================================

# Groq API Key (wajib) — daftar gratis di console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# =============================================
# LANGSMITH CONFIGURATION (untuk tracing)
# =============================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-langsmith-api-key-here
LANGCHAIN_PROJECT=customer-service-chatbot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =============================================
# APLIKASI
# =============================================
APP_NAME=Customer Service Chatbot
APP_VERSION=1.0.0
DEBUG=false
